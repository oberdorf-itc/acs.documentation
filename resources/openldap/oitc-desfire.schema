attributetype ( 1.3.6.1.4.1.46756.3.1.1.13 NAME 'oitcRFIDSoftwareProtocol'
        DESC 'The software protocol'
        EQUALITY caseIgnoreIA5Match
        SYNTAX 1.3.6.1.4.1.1466.115.121.1.26{2} SINGLE-VALUE )

# PICC Level configuration

attributetype ( 1.3.6.1.4.1.46756.3.1.1.14 NAME 'oitcRFIDpICCLevelCryptoType'
        DESC 'The cipher to use to authenticate to PICC (DES, AES, TDES, ...)'
        EQUALITY caseIgnoreIA5Match
        SYNTAX 1.3.6.1.4.1.1466.115.121.1.26 SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.46756.3.1.1.15 NAME 'oitcRFIDpICCLevelMasterKey'
        DESC 'The PICC master key in HEX notation'
        EQUALITY caseIgnoreIA5Match
        SYNTAX 1.3.6.1.4.1.1466.115.121.1.26{48} SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.46756.3.1.1.16 NAME 'oitcRFIDpICCLevelChangeMasterKeyAllowed'
        DESC 'RFID transponder PICC level configuration: change master key allowed'
        EQUALITY booleanMatch
        SYNTAX 1.3.6.1.4.1.1466.115.121.1.7 SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.46756.3.1.1.17 NAME 'oitcRFIDpICCLevelDirectoryListWithMasterKey'
        DESC 'RFID transponder PICC level configuration: Directory list with master key'
        EQUALITY booleanMatch
        SYNTAX 1.3.6.1.4.1.1466.115.121.1.7 SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.46756.3.1.1.18 NAME 'oitcRFIDpICCLevelCreateDeleteWithMasterKey'
        DESC 'RFID transponder PICC level configuration: Create/Delete with master key'
        EQUALITY booleanMatch
        SYNTAX 1.3.6.1.4.1.1466.115.121.1.7 SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.46756.3.1.1.19 NAME 'oitcRFIDpICCLevelConfigurationChangeable'
        DESC 'RFID transponder PICC level configuration: configuration changeable'
        EQUALITY booleanMatch
        SYNTAX 1.3.6.1.4.1.1466.115.121.1.7 SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.46756.3.1.1.20 NAME 'oitcRFIDpICCLevelRandomTransponderID'
        DESC 'RFID transponder PICC level configuration: usage of random transponder ID'
        EQUALITY booleanMatch
        SYNTAX 1.3.6.1.4.1.1466.115.121.1.7 SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.46756.3.1.1.21 NAME 'oitcRFIDpICCLevelFormatAllowed'
        DESC 'RFID transponder PICC level configuration: Is it allowed to format the RFID transponder'
        EQUALITY booleanMatch
        SYNTAX 1.3.6.1.4.1.1466.115.121.1.7 SINGLE-VALUE )

