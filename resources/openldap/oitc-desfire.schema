#############################################################################
# Object Class Definitions (1.3.6.1.4.1.46756.3.1.2.x)

objectclass ( 1.3.6.1.4.1.46756.3.1.2.0 NAME 'oitcTransponder'
	DESC 'Abstraction of a RFID transponder chip'
	SUP top STRUCTURAL
        MUST oitcTransponderID
        MAY ( macAddress $ oitcTransponderType $ oitcRFIDHardwareVendorID $
                oitcRFIDHardwareType $ oitcRFIDHardwareVendorID $ oitcRFIDHardwareType $
                oitcRFIDHardwareSubtype $ oitcRFIDHardwareVersion $ oitcRFIDHardwareStorage $
                oitcRFIDHardwareProtocol $ oitcRFIDSoftwareVendorID $ oitcRFIDSoftwareType $
                oitcRFIDSoftwareSubtype $ oitcRFIDSoftwareVersion $ oitcRFIDSoftwareStorage $
                oitcRFIDSoftwareProtocol $ oitcRFIDpICCLevelCryptoType $ oitcRFIDpICCLevelMasterKey $
                oitcRFIDpICCLevelChangeMasterKeyAllowed $ oitcRFIDpICCLevelDirectoryListWithMasterKey $
                oitcRFIDpICCLevelCreateDeleteWithMasterKey $ oitcRFIDpICCLevelConfigurationChangeable $
                oitcRFIDpICCLevelRandomTransponderID $ oitcRFIDpICCLevelFormatAllowed $
                description ) )

objectclass ( 1.3.6.1.4.1.46756.3.1.2.1 NAME 'oitcDESFireApplication'
	DESC 'Abstraction of a MIFARE DESFire EV1 application'
        SUP top STRUCTURAL
        MUST oitcRFIDApplicationID
        MAY ( oitcRFIDApplicationCryptoType $ oitcRFIDApplicationNumberOfKeys $
                oitcRFIDApplicationChangeKey $ oitcRFIDApplicationChangeMasterKeyAllowed $
                oitcRFIDApplicationDirectoryListWithMasterKey $ oitcRFIDApplicationCreateDeleteWithMasterKey $
                oitcRFIDApplicationConfigurationChangeable $ oitcRFIDApplicationKey01 $
                oitcRFIDApplicationKey02 $ oitcRFIDApplicationKey03 $ oitcRFIDApplicationKey04 $
                oitcRFIDApplicationKey05 $ oitcRFIDApplicationKey06 $ oitcRFIDApplicationKey07 $
                oitcRFIDApplicationKey08 $ oitcRFIDApplicationKey09 $ oitcRFIDApplicationKey10 $
                oitcRFIDApplicationKey11 $ oitcRFIDApplicationKey12 $ oitcRFIDApplicationKey13 $
                oitcRFIDApplicationKey14 $ description ) )

objectclass ( 1.3.6.1.4.1.46756.3.1.2.2 NAME 'oitcDESFireStandardDataFile'
        DESC 'Abstraction of a MIFARE DESFire EV1 standard data file'
        SUP top STRUCTURAL
        MUST oitcRFIDFileID
        MAY ( oitcRFIDFileCommunication $ oitcRFIDFileAccessReadKey $ oitcRFIDFileAccessWriteKey $
                oitcRFIDFileAccessReadWriteKey $ oitcRFIDFileAccessChangeKey $ oitcRFIDFileSize $
                description ) )

objectclass ( 1.3.6.1.4.1.46756.3.1.2.3 NAME 'oitcDESFireBackupDataFile'
        DESC 'Abstraction of a MIFARE DESFire EV1 backup data file'
        SUP top STRUCTURAL
        MUST oitcRFIDFileID
        MAY ( oitcRFIDFileCommunication $ oitcRFIDFileAccessReadKey $ oitcRFIDFileAccessWriteKey $
                oitcRFIDFileAccessReadWriteKey $ oitcRFIDFileAccessChangeKey $ oitcRFIDFileSize $
                description ) )

objectclass ( 1.3.6.1.4.1.46756.3.1.2.4 NAME 'oitcDESFireValueFile'
        DESC 'Abstraction of a MIFARE DESFire EV1 value file'
        SUP top STRUCTURAL
        MUST oitcRFIDFileID
        MAY ( oitcRFIDFileCommunication $ oitcRFIDFileAccessReadKey $ oitcRFIDFileAccessWriteKey $
                oitcRFIDFileAccessReadWriteKey $ oitcRFIDFileAccessChangeKey $ oitcRFIDFileLowerLimit $
                oitcRFIDFileUpperLimit $ oitcRFIDFileValue $ oitcRFIDFileLimitedCreditEnabled $
                description ) )

objectclass ( 1.3.6.1.4.1.46756.3.1.2.5 NAME 'oitcDESFireLinearRecordFile'
        DESC 'Abstraction of a MIFARE DESFire EV1 linear record file'
        SUP top STRUCTURAL
        MUST oitcRFIDFileID
        MAY ( oitcRFIDFileCommunication $ oitcRFIDFileAccessReadKey $ oitcRFIDFileAccessWriteKey $
                oitcRFIDFileAccessReadWriteKey $ oitcRFIDFileAccessChangeKey $
                oitcRFIDFileRecordSize $ oitcRFIDFileRecordCount $ description ) )

objectclass ( 1.3.6.1.4.1.46756.3.1.2.6 NAME 'oitcDESFireCyclicRecordFile'
        DESC 'Abstraction of a MIFARE DESFire EV1 cyclic record file'
        SUP top STRUCTURAL
        MUST oitcRFIDFileID
        MAY ( oitcRFIDFileCommunication $ oitcRFIDFileAccessReadKey $ oitcRFIDFileAccessWriteKey $
                oitcRFIDFileAccessReadWriteKey $ oitcRFIDFileAccessChangeKey $
                oitcRFIDFileRecordSize $ oitcRFIDFileRecordCount $ description ) )
