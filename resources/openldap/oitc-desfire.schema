# Attribute Type Definitions (1.3.6.1.4.1.46756.3.1.1.x)

# General transponder data

attributetype ( 1.3.6.1.4.1.46756.3.1.1.0 NAME 'oitcTransponderID'
        DESC 'A RFID transponder unique ID'
        EQUALITY caseIgnoreIA5Match
        SYNTAX 1.3.6.1.4.1.1466.115.121.1.26 SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.46756.3.1.1.1 NAME 'oitcTransponderType'
        DESC 'A RFID transponder type name (such as MIFARE DESFire EV1)'
        EQUALITY caseIgnoreIA5Match
        SYNTAX 1.3.6.1.4.1.1466.115.121.1.26 SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.46756.3.1.1.2 NAME 'oitcRFIDHardwareVendorID'
        DESC 'The hardware vendor ID of the RFID transponder'
        EQUALITY caseIgnoreIA5Match
        SYNTAX 1.3.6.1.4.1.1466.115.121.1.26{2} SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.46756.3.1.1.3 NAME 'oitcRFIDHardwareType'
        DESC 'The hardware type of the RFID transponder'
        EQUALITY caseIgnoreIA5Match
        SYNTAX 1.3.6.1.4.1.1466.115.121.1.26{2} SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.46756.3.1.1.4 NAME 'oitcRFIDHardwareSubtype'
        DESC 'The hardware subtype of the RFID transponder'
        EQUALITY caseIgnoreIA5Match
        SYNTAX 1.3.6.1.4.1.1466.115.121.1.26{2} SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.46756.3.1.1.5 NAME 'oitcRFIDHardwareVersion'
        DESC 'The hardware version of the RFID transponder'
        EQUALITY caseIgnoreIA5Match
        SYNTAX 1.3.6.1.4.1.1466.115.121.1.26 SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.46756.3.1.1.6 NAME 'oitcRFIDHardwareStorage'
        DESC 'The hardware storage size in bytes of the RFID transponder'
        EQUALITY integerMatch
        SYNTAX 1.3.6.1.4.1.1466.115.121.1.27 SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.46756.3.1.1.7 NAME 'oitcRFIDHardwareProtocol'
        DESC 'The hardware protocol'
        EQUALITY caseIgnoreIA5Match
        SYNTAX 1.3.6.1.4.1.1466.115.121.1.26{2} SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.46756.3.1.1.8 NAME 'oitcRFIDSoftwareVendorID'
