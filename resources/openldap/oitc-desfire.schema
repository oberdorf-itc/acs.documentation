        DESC 'The software subtype of the RFID transponder'
        EQUALITY caseIgnoreIA5Match
        SYNTAX 1.3.6.1.4.1.1466.115.121.1.26{2} SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.46756.3.1.1.11 NAME 'oitcRFIDSoftwareVersion'
        DESC 'The software version of the RFID transponder'
        EQUALITY caseIgnoreIA5Match
