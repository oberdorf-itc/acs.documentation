dn: ou=Notify Configuration,ou=OITC Access Control System,dc=oberdorf-itc,dc=de
description: Reader Notification Configuration
objectClass: organizationalUnit
ou: Notify Configuration

dn: oitcACSNotifyId=error,ou=Notify Configuration,ou=OITC Access Control System,dc=oberdorf-itc,dc=de
description: Signal bei Fehlern wie zum Beispiel unauthorisierter Zugangsversuch
oitcACSNotifyLEDNumber: 2
objectClass: oitcACSNotifyConfiguration
oitcACSNotifyBuzzer: TRUE
oitcACSNotifyId: error
oitcACSNotifyLED: TRUE
oitcACSNotifySignalIntervalType: 2
oitcACSNotifySignalTime: 7

dn: oitcACSNotifyId=ok,ou=Notify Configuration,ou=OITC Access Control System,dc=oberdorf-itc,dc=de
description: Signal wenn Authentisierung erfolgreich
oitcACSNotifyLEDNumber: 1
objectClass: oitcACSNotifyConfiguration
oitcACSNotifyBuzzer: TRUE
oitcACSNotifyId: ok
oitcACSNotifyLED: TRUE
oitcACSNotifySignalIntervalType: 1
oitcACSNotifySignalTime: 4

dn: oitcACSNotifyId=init,ou=Notify Configuration,ou=OITC Access Control System,dc=oberdorf-itc,dc=de
description: Signal bei Leser Initialisierung
oitcACSNotifyLEDNumber: 3
objectClass: oitcACSNotifyConfiguration
oitcACSNotifyBuzzer: TRUE
oitcACSNotifyId: init
oitcACSNotifyLED: TRUE
oitcACSNotifySignalIntervalType: 1
oitcACSNotifySignalTime: 3
